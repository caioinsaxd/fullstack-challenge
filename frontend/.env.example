# Frontend Environment Variables
# Copy this file to .env and modify the values as needed for your environment

# API URL for the Kong gateway (proxy to backend services)
# Format: http://localhost:8000
VITE_API_URL=http://localhost:8000

# WebSocket URL for real-time game updates
# Connects directly to the Game Service WebSocket endpoint
# Format: ws://localhost:4001
VITE_WS_URL=ws://localhost:4001

# Redirect URI for OAuth2/OIDC authentication flow
# Must match exactly what's configured in Keycloak client settings
# Format: http://localhost:3000
VITE_REDIRECT_URI=http://localhost:3000

# Optional: Keycloak URL (if different from default)
# Format: http://localhost:8080/realms/crash-game
# VITE_KEYCLOAK_URL=http://localhost:8080/realms/crash-game