generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Round {
  id            String    @id @default(uuid()) @map("id")
  status        String    @default("BETTING") @map("status")
  crashPoint    Decimal?  @db.Decimal(10, 2) @map("crashpoint")
  hash          String?   @map("hash")
  seed          String?   @map("seed")
  startedAt     DateTime? @map("startedat")
  crashedAt     DateTime? @map("crashedat")
  settledAt     DateTime? @map("settledat")
  createdAt     DateTime  @default(now()) @map("createdat")
  updatedAt     DateTime  @updatedAt @map("updatedat")
  bets          Bet[]

  @@map("round")
}

model Bet {
  id                 String    @id @default(uuid()) @map("id")
  roundId           String    @map("roundid")
  playerId           String    @map("playerid")
  amount             Int       @map("amount")
  status             String    @default("PENDING") @map("status")
  cashoutMultiplier Decimal?  @db.Decimal(10, 2) @map("cashoutmultiplier")
  cashoutedAt       DateTime? @map("cashoutedat")
  createdAt          DateTime  @default(now()) @map("createdat")
  updatedAt          DateTime  @updatedAt @map("updatedat")
  round              Round     @relation(fields: [roundId], references: [id])

  @@map("bet")
}